# ─── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-change-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=resumeai
POSTGRES_USER=resumeai
POSTGRES_PASSWORD=strongpassword
DATABASE_URL=postgresql://resumeai:strongpassword@db:5432/resumeai

# ─── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─── Google Gemini ────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-pro

# ─── Google Cloud Storage ─────────────────────────────────────────────────────
# 1. Create a GCS bucket in your Google Cloud project
# 2. Create a service account with roles/storage.objectAdmin
# 3. Download the JSON key → save as gcs-credentials.json in project root
# 4. Fill in the two values below
GCS_BUCKET_NAME=your-gcs-bucket-name
GCS_PROJECT_ID=your-google-cloud-project-id
# GOOGLE_APPLICATION_CREDENTIALS is set automatically by docker-compose

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ─── Storage ──────────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
